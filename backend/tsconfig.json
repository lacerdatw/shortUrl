{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": ".build",
    "rootDir": "src"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", ".build"]
}
