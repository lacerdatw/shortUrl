AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# Must match table names created by serverless deploy (shorturl-urls-dev / shorturl-users-dev)
DYNAMODB_TABLE_URLS=shorturl-urls-dev
DYNAMODB_TABLE_USERS=shorturl-users-dev

PORT=3000
BASE_URL=http://localhost:3000

JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=24h
